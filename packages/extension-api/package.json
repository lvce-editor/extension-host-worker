{
  "name": "@lvce-editor/extension-api",
  "version": "0.0.0-dev",
  "description": "Tree-shakeable extension API for Lvce Editor extensions.",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./activation": {
      "types": "./src/parts/Activation/Activation.ts",
      "default": "./src/parts/Activation/Activation.ts"
    },
    "./command": {
      "types": "./src/parts/Command/Command.ts",
      "default": "./src/parts/Command/Command.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "type-check": "tsc"
  }
}
