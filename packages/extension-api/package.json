{
  "name": "@lvce-editor/api",
  "version": "0.0.0-dev",
  "description": "Tree-shakeable extension API for Lvce Editor extensions.",
  "keywords": [
    "lvce-editor",
    "extension-api"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvce-editor/extension-host-worker.git",
    "directory": "packages/extension-api"
  },
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
